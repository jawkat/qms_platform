# =============================================================================
# QMS Platform — Environment Variables
# =============================================================================
# Copiez ce fichier en .env et adaptez les valeurs à votre environnement.
#
# IMPORTANT : Ne jamais commit le fichier .env dans le repository.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=qms_platform
POSTGRES_USER=qms_user
POSTGRES_PASSWORD=qms_password
DATABASE_URL=postgresql+psycopg2://qms_user:qms_password@db:5432/qms_platform

# --- Flask ---
SECRET_KEY=change-me-with-a-long-secret-key
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5005

# --- Admin Bootstrap ---
ADMIN_EMAIL=jwd.katten@gmail.com
ADMIN_PASSWORD=admin123
AUTO_BOOTSTRAP=1

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MINIO (Stockage objet S3-compatible) ---
# Console web : http://localhost:9001
# API S3 : http://localhost:9000
# Si MINIO_ENDPOINT est vide, le stockage local est utilisé automatiquement.
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD sont utilisés par le conteneur MinIO.
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY sont utilisés par l'application Flask.
# Les deux paires doivent avoir les mêmes valeurs.
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=qms-platform

# --- Email (optionnel) ---
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USE_SSL=0
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@qmsplatform.ma
MAIL_SUPPRESS_SEND=0

# --- App URL (pour les liens dans les emails) ---
APP_LOGIN_URL=http://localhost:5005/

# --- Logging ---
LOG_LEVEL=INFO
